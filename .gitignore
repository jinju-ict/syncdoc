# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
.env.local

# uploaded attachments (디스크 저장 — 커밋하지 않는다)
/uploads

# sqlite database (백업 파일 포함 — DB는 어떤 형태로도 커밋하지 않는다)
*.db
*.db-journal
*.db-wal
*.db-shm
*.db.bak-*
*.db-wal.bak-*
*.db-shm.bak-*

# OMC plugin state
.omc/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
