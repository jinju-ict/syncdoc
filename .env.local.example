# SyncDoc 환경변수 — 이 파일을 .env.local로 복사해 값을 채우세요.
# AI 기능(번역/제안/Abstract)은 아래 세 프로바이더 중 하나만 설정하면 동작합니다.
# 미설정 시 기능은 failed로 기록되고 재시도 버튼이 노출됩니다 (문서 히스토리는 안전).

# ── AI 프로바이더 선택 ─────────────────────────────────────────────
# anthropic | openai | ollama (생략 시 자동 감지: ANTHROPIC_API_KEY → OPENAI_API_KEY → OLLAMA_MODEL 순)
AI_PROVIDER=

# [1] Anthropic (Claude)
ANTHROPIC_API_KEY=
# 모델 (선택, 기본 claude-opus-4-8 — 비용 절감 시 claude-sonnet-4-6)
ANTHROPIC_MODEL=

# [2] OpenAI
OPENAI_API_KEY=
# 모델 (openai 사용 시 필수, 예: gpt-5-mini)
OPENAI_MODEL=
# API 주소 (선택, 기본 https://api.openai.com/v1 — 호환 프록시 사용 시 변경)
OPENAI_BASE_URL=

# [3] 로컬 모델 — Ollama / LM Studio 등 OpenAI 호환 서버
# 모델 (ollama 사용 시 필수, 예: qwen3:8b, llama3.1:8b — 미리 `ollama pull` 해둘 것)
OLLAMA_MODEL=
# 서버 주소 (선택, 기본 http://localhost:11434/v1 — LM Studio는 http://localhost:1234/v1)
OLLAMA_BASE_URL=

# ── 기타 ──────────────────────────────────────────────────────────
# 세션 서명용 HMAC 시크릿 (선택 — 미설정 시 개발용 기본값 사용. 운영에서는 반드시 설정)
SESSION_SECRET=

# SQLite 파일 경로 (선택, 기본값: <프로젝트 루트>/syncdoc.db)
# SYNCDOC_DB_PATH=
