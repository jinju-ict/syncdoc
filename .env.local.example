# SyncDoc 환경변수 — 이 파일을 .env.local로 복사해 값을 채우세요.

# Claude API 키 (필수 — 없으면 번역/제안/Abstract가 failed로 기록되고 재시도 버튼이 노출됨)
ANTHROPIC_API_KEY=

# 사용할 Claude 모델 (선택, 기본값: claude-opus-4-8 — 비용 절감 시 claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-opus-4-8

# 세션 서명용 HMAC 시크릿 (선택 — 미설정 시 개발용 기본값 사용. 운영에서는 반드시 설정)
SESSION_SECRET=

# SQLite 파일 경로 (선택, 기본값: <프로젝트 루트>/syncdoc.db)
# SYNCDOC_DB_PATH=
